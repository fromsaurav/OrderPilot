#!/bin/bash
# k3s AGENT bootstrap. Waits for the server's API to answer, then joins the cluster using the
# shared token + the server's private IP (node-to-node traffic stays inside the VPC).
set -euxo pipefail

until curl -sk "https://${server_private_ip}:6443/ping" >/dev/null 2>&1; do
  echo "waiting for k3s server at ${server_private_ip}:6443..."
  sleep 5
done

curl -sfL https://get.k3s.io | K3S_URL="https://${server_private_ip}:6443" \
  K3S_TOKEN="${k3s_token}" sh -

touch /tmp/k3s-agent-joined
