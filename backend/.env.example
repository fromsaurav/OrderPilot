# Copy to .env for local overrides. NEVER commit a real .env (see .gitignore).
# Defaults in app/config.py already work with docker-compose; this file documents the knobs.

TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TASK_QUEUE=order-supervisor

DB_HOST=localhost
DB_PORT=5432
DB_USER=temporal
DB_PASSWORD=temporal
DB_NAME=orderpilot

# Decision #9 defaults (per-run overridable at start)
DEFAULT_WAKE_INTERVAL_SECONDS=60
DEFAULT_MAX_RUN_AGE_SECONDS=86400

# Decision #3: the single Gemini call site (classifies customer_message_received text).
# Enabled by default but INERT until you supply a key here — so with no key the system runs
# purely on rules, and just adding GEMINI_API_KEY turns the LLM path on. Never commit a real key.
LLM_ENABLED=true
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
