# Copy to .env for local overrides. NEVER commit a real .env (see .gitignore).
# Defaults in app/config.py already work with docker-compose; this file documents the knobs.

TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TASK_QUEUE=order-supervisor

DB_HOST=localhost
DB_PORT=5432
DB_USER=temporal
DB_PASSWORD=temporal
DB_NAME=orderpilot

# Decision #9 defaults (per-run overridable at start)
DEFAULT_WAKE_INTERVAL_SECONDS=60
DEFAULT_MAX_RUN_AGE_SECONDS=86400

# Decision #3: leave LLM off for the deterministic demo. To enable the single Gemini
# call site, set LLM_ENABLED=true and provide a key (never commit it).
LLM_ENABLED=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
