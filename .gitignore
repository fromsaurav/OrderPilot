# ---- Secrets & credentials (HARD CONSTRAINT: never commit) ----
.env
.env.*
!.env.example
!.env*.example
*.pem
*.key
*.crt
**/secrets*
**/*secret*
# the generated kubeconfig (has cluster creds) lives at repo root; ignore just that file,
# not scripts whose name contains "kubeconfig" (e.g. scripts/fetch_kubeconfig.sh)
/kubeconfig
*.kubeconfig
.aws/
credentials

# ---- Terraform (never commit state) ----
# NOTE: .terraform.lock.hcl IS committed on purpose (pins provider versions for reproducibility).
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---- Node / Next.js ----
node_modules/
.next/
out/
npm-debug.log*
yarn-error.log*

# ---- OS / editor ----
.DS_Store
.idea/
.vscode/
*.swp

# Terraform binary plan files
tfplan
*.tfplan
