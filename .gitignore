# ---- Secrets & credentials (HARD CONSTRAINT: never commit) ----
.env
.env.*
!.env.example
*.pem
*.key
*.crt
**/secrets*
**/*secret*
kubeconfig
*kubeconfig*
.aws/
credentials

# ---- Terraform (never commit state) ----
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

